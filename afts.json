{
  "LLM": {
    "provider": "xai",
    "model": "grok-4-1-fast-non-reasoning",
    "api_key": "XAI_API_KEY"
  },
  "advisor": {
    "system": "./advisor/prompt.md",
    "scan": "./advisor/SCAN.md",
    "decide": "./advisor/DECIDE.md",
    "loss": "./advisor/LOSS.md"
  },
  "database": {
    "type": "sqlite",
    "name": "afts.db"
  },
  "logging": {
    "level": "INFO",
    "file": "./logs/afts.log",
    "maxBytes": 10485760,
    "backupCount": 5
  },
  "unittest": {
    "default": "./usercase/autocase/default.md",
    "scanPath": "./usercase/autocase/SCAN/",
    "decidePath": "./usercase/autocase/DECIDE/",
    "lossPath": "./usercase/autocase/LOSS/"
  }
}

